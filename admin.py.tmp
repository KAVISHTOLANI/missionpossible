@admin_bp.route("/api/live/matches", methods=["POST"])\r
@login_required\r
def api_live_matches_create():\r
    body = request.get_json(silent=True) or {}\r
    match, error = _build_match(body)\r
    if error:\r
        return jsonify({"ok": False, "error": error}), 400\r
    scores = _save_match(match)\r
    audit("live_match_create", f"{match['match_id']} {match['event_id']} {match['status']}")\r
    return jsonify({"ok": True, "match": match, "live": scores.get("live", {})}), 201\r
\r

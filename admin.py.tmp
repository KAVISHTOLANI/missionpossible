ALLOWED_CHAMPION_EXT = {"png", "jpg", "jpeg", "webp"}\r
VALID_TEAM_IDS = {"creators", "dominators", "royals"}\r
VALID_STATUSES = {"upcoming", "live", "completed"}\r
VALID_TAGS = {"Urgent", "Info", "Result"}\r

# ---------------------------------------------------------------------------\r
# Write API â€” Awards\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/awards/update", methods=["POST"])\r
@login_required\r
def update_awards():\r
    body = request.get_json(silent=True) or {}\r
    awards = _load("awards.json", {"event_mvps": {}, "overall_best_player": None, "best_team": None, "fair_play_award": None})\r
\r
    kind = body.get("kind")\r
    if kind == "event_mvp":\r
        event_id = body.get("event_id")\r
        if not event_id:\r
            return jsonify({"ok": False, "error": "event_id required"}), 400\r
        events = {e.get("id"): e for e in _load("events.json", [])}\r
        event = events.get(event_id)\r
        if not event:\r
            return jsonify({"ok": False, "error": "Unknown event"}), 400\r
        if (event.get("badge") or "").lower() in {"cultural", "finale"}:\r
            return jsonify({"ok": False, "error": "MVP is disabled for cultural events"}), 400\r
        awards.setdefault("event_mvps", {})[event_id] = {\r
            "player": (body.get("player") or "").strip(),\r
            "team": body.get("team") if body.get("team") in VALID_TEAM_IDS else None,\r
            "image": (body.get("image") or "").strip(),\r
        }\r
    elif kind == "best_player":\r
        awards["overall_best_player"] = {\r
            "player": (body.get("player") or "").strip(),\r
            "team": body.get("team") if body.get("team") in VALID_TEAM_IDS else None,\r
            "image": (body.get("image") or "").strip(),\r
        }\r
    elif kind == "best_team":\r
        awards["best_team"] = body.get("team") if body.get("team") in VALID_TEAM_IDS else None\r
    elif kind == "fair_play":\r
        awards["fair_play_award"] = body.get("team") if body.get("team") in VALID_TEAM_IDS else None\r
    elif kind == "clear_all":\r
        awards = {"event_mvps": {}, "overall_best_player": None, "best_team": None, "fair_play_award": None}\r
    else:\r
        return jsonify({"ok": False, "error": "Unknown award kind"}), 400\r
\r
    _save("awards.json", awards)\r
    audit("awards_update", kind)\r
    return jsonify({"ok": True, "awards": awards})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Champions\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/champions/save", methods=["POST"])\r
@login_required\r
def save_champion():\r
    body = request.form if request.content_type and request.content_type.startswith("multipart/form-data") else (request.get_json(silent=True) or {})\r
    event_id = (body.get("event_id") or "").strip()\r
    champion_type = (body.get("champion_type") or "team").strip().lower()\r
    sport_category = (body.get("sport_category") or "").strip()\r
    team_id = body.get("team")\r
    player_name = (body.get("player_name") or "").strip()\r
    team_name = (body.get("team_name") or "").strip()\r
    if hasattr(body, "getlist"):\r
        players = body.getlist("players")\r
    else:\r
        players = body.get("players") if isinstance(body.get("players"), list) else []\r
    players = [str(p).strip() for p in players if str(p).strip()]\r
\r
    events = {e.get("id"): e for e in _load("events.json", [])}\r
    if event_id not in events:\r
        return jsonify({"ok": False, "error": "Unknown event"}), 400\r
    if champion_type not in {"team", "individual"}:\r
        return jsonify({"ok": False, "error": "Invalid champion type"}), 400\r
\r
    teams = {t.get("id"): t for t in _load("teams.json", [])}\r
    champions = _load("champions.json", [])\r
    row = next((x for x in champions if x.get("event_id") == event_id), None)\r
    if not row:\r
        row = {"event_id": event_id}\r
        champions.append(row)\r
\r
    row["event_id"] = event_id\r
    row["event_name"] = events[event_id].get("name", event_id)\r
    row["sport_category"] = sport_category\r
    row["champion_type"] = champion_type\r
    row["team"] = team_id if team_id in teams else None\r
    row["team_name"] = team_name or (teams[team_id]["name"] if team_id in teams else "")\r
    second_team_id = body.get("second_team")\r
    second_team_name = (body.get("second_team_name") or "").strip()\r
    row["second_team"] = second_team_id if second_team_id in teams else None\r
    row["second_team_name"] = second_team_name or (teams[second_team_id]["name"] if second_team_id in teams else "")\r
    row["player_name"] = player_name\r
    row["second_player_name"] = (body.get("second_player_name") or "").strip()\r
    row["players"] = players\r
    if "winning_photo" in request.files and request.files["winning_photo"].filename:\r
        file = request.files["winning_photo"]\r
        ext = file.filename.rsplit(".", 1)[-1].lower() if "." in file.filename else ""\r
        if ext not in ALLOWED_CHAMPION_EXT:\r
            return jsonify({"ok": False, "error": "Winning photo must be PNG, JPG, JPEG, or WEBP"}), 400\r
        upload_dir = os.path.join(_BASE_DIR, "static", "images", "champions")\r
        os.makedirs(upload_dir, exist_ok=True)\r
        filename = secure_filename(f"{event_id}-{uuid.uuid4().hex[:8]}.{ext}")\r
        file.save(os.path.join(upload_dir, filename))\r
        row["winning_photo"] = f"/static/images/champions/{filename}"\r
    else:\r
        row["winning_photo"] = (body.get("winning_photo") or row.get("winning_photo") or "").strip()\r
    row["updated_at"] = datetime.now().strftime("%Y-%m-%d %H:%M")\r
\r
    _save("champions.json", champions)\r
    audit("champion_save", f"{event_id} {champion_type}")\r
    return jsonify({"ok": True, "champion": row})\r
\r
\r
@admin_bp.route("/api/champions/delete", methods=["POST"])\r
@login_required\r
def delete_champion():\r
    event_id = ((request.get_json(silent=True) or {}).get("event_id") or "").strip()\r
    if not event_id:\r
        return jsonify({"ok": False, "error": "event_id required"}), 400\r
    champions = _load("champions.json", [])\r
    champions = [x for x in champions if x.get("event_id") != event_id]\r
    _save("champions.json", champions)\r
    audit("champion_delete", event_id)\r
    return jsonify({"ok": True})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Event details (sports page cards + sport detail header info)\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/events/update", methods=["POST"])\r
@login_required\r
def update_event_details():\r
    body = request.get_json(silent=True) or {}\r
    event_id = body.get("event_id")\r
    events = _load("events.json", [])\r
    event = next((e for e in events if e.get("id") == event_id), None)\r
    if not event:\r
        return jsonify({"ok": False, "error": "Unknown event"}), 400\r
\r
    name = (body.get("name") or "").strip()\r
    if not name:\r
        return jsonify({"ok": False, "error": "Event name is required"}), 400\r
\r
    badge = body.get("badge") if body.get("badge") in VALID_BADGES else event.get("badge", "sports")\r
    status = body.get("status") if body.get("status") in VALID_STATUSES else event.get("status", "upcoming")\r
    banner = body.get("banner") if body.get("banner") in VALID_BANNERS else event.get("banner", "")\r
\r
    try:\r
        winner_pts = int(body.get("winner_points", event.get("points", {}).get("winner", 300)))\r
        runner_pts = int(body.get("runner_up_points", event.get("points", {}).get("runner_up", 150)))\r
    except (TypeError, ValueError):\r
        return jsonify({"ok": False, "error": "Points must be numbers"}), 400\r
\r
    iso_date = (body.get("iso_date") or "").strip()\r
    if iso_date:\r
        try:\r
            datetime.strptime(iso_date, "%Y-%m-%d")\r
        except ValueError:\r
            return jsonify({"ok": False, "error": "iso_date must be YYYY-MM-DD"}), 400\r
\r
    event["name"] = name\r
    event["num"] = (body.get("num") or "").strip() or event.get("num", "")\r
    event["emoji"] = (body.get("emoji") or "").strip() or event.get("emoji", "ðŸ†")\r
    event["date"] = (body.get("date") or "").strip()\r
    event["day"] = (body.get("day") or "").strip()\r
    event["iso_date"] = iso_date or event.get("iso_date", "")\r
    event["category"] = (body.get("category") or "").strip()\r
    event["venue"] = (body.get("venue") or "").strip()\r
    event["location"] = (body.get("location") or "").strip()\r
    event["venue_maps_link"] = (body.get("venue_maps_link") or "").strip()\r
    event["weather"] = (body.get("weather") or "").strip()\r
    event["weather_icon"] = (body.get("weather_icon") or "").strip()\r
    event["weather_note"] = (body.get("weather_note") or "").strip()\r
    event["event_time"] = (body.get("event_time") or "").strip()\r
    event["tournament_format"] = (body.get("tournament_format") or "").strip()\r
    results = body.get("results")\r
    event["results"] = results if isinstance(results, list) else event.get("results", [])\r
    event["badge"] = badge\r
    event["status"] = status\r
    event["banner"] = banner\r
    event["points"] = {"winner": max(0, winner_pts), "runner_up": max(0, runner_pts)}\r
\r
    _save("events.json", events)\r
\r
    scores = _load("scores.json", {})\r
    live = scores.get("live") or {}\r
    if live.get("event_id") == event_id:\r
        live["event_name"] = name\r
        _save("scores.json", scores)\r
\r
    audit("event_update", f"{event_id}: {name}")\r
    return jsonify({"ok": True, "event": event})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Event rules\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/events/rules", methods=["POST"])\r
@login_required\r
def update_rules():\r
    body = request.get_json(silent=True) or {}\r
    event_id = body.get("event_id")\r
    rules = body.get("rules")\r
    if not isinstance(rules, list):\r
        return jsonify({"ok": False, "error": "rules must be a list"}), 400\r
    rules = [str(r).strip() for r in rules if str(r).strip()]\r
\r
    events = _load("events.json", [])\r
    found = False\r
    for e in events:\r
        if e["id"] == event_id:\r
            e["rules"] = rules\r
            found = True\r
            break\r
    if not found:\r
        return jsonify({"ok": False, "error": "Unknown event"}), 400\r
    _save("events.json", events)\r
    audit("rules_update", f"{event_id} ({len(rules)} rules)")\r
    return jsonify({"ok": True, "rules": rules})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Logo upload\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/logos/upload", methods=["POST"])\r
@login_required\r
def upload_logo():\r
    team_id = request.form.get("team")\r
    if team_id not in VALID_TEAM_IDS:\r
        return jsonify({"ok": False, "error": "Unknown team"}), 400\r
    file = request.files.get("logo")\r
    if not file or file.filename == "":\r
        return jsonify({"ok": False, "error": "No file uploaded"}), 400\r
    ext = file.filename.rsplit(".", 1)[-1].lower() if "." in file.filename else ""\r
    if ext not in ALLOWED_LOGO_EXT:\r
        return jsonify({"ok": False, "error": "PNG files only"}), 400\r
\r
    dest_dir = os.path.join(_BASE_DIR, "static", "images", "logos")\r
    os.makedirs(dest_dir, exist_ok=True)\r
    filename = secure_filename(f"{team_id}.png")\r
    file.save(os.path.join(dest_dir, filename))\r
    audit("logo_upload", team_id)\r
    return jsonify({"ok": True, "path": f"/static/images/logos/{filename}"})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Gallery upload/delete\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/gallery/upload", methods=["POST"])\r
@login_required\r
def upload_gallery():\r
    files = request.files.getlist("images")\r
    caption = (request.form.get("caption") or "").strip()\r
    if not files:\r
        return jsonify({"ok": False, "error": "No files uploaded"}), 400\r
\r
    dest_dir = os.path.join(_BASE_DIR, "static", "images", "gallery", "season-4")\r
    os.makedirs(dest_dir, exist_ok=True)\r
    seasons = _load("gallery_seasons.json", [])\r
    season4 = next((s for s in seasons if s.get("id") == "season-4"), None)\r
    if not season4:\r
        season4 = {\r
            "id": "season-4",\r
            "season": "Season 4",\r
            "name": "Mission Possible",\r
            "year": "2026",\r
            "tagline": "Beyond Impossible",\r
            "photos": [],\r
        }\r
        seasons.insert(0, season4)\r
    season4.setdefault("photos", [])\r
    added = []\r
\r
    for file in files:\r
        if not file or not file.filename:\r
            continue\r
        ext = file.filename.rsplit(".", 1)[-1].lower() if "." in file.filename else ""\r
        if ext not in ALLOWED_GALLERY_EXT:\r
            continue\r
        gid = "gal-" + uuid.uuid4().hex[:10]\r
        filename = secure_filename(f"{gid}.{ext}")\r
        file.save(os.path.join(dest_dir, filename))\r
        item = {\r
            "id": gid,\r
            "path": f"/static/images/gallery/season-4/{filename}",\r
            "caption": caption or "Mission Possible 2026",\r
            "uploaded_at": datetime.now().strftime("%Y-%m-%d %H:%M"),\r
        }\r
        season4["photos"].insert(0, item)\r
        added.append(item)\r
\r
    if not added:\r
        return jsonify({"ok": False, "error": "No valid images (png/jpg/jpeg/webp)"}), 400\r
\r
    _save("gallery_seasons.json", seasons)\r
    audit("gallery_upload", f"{len(added)} image(s)")\r
    return jsonify({"ok": True, "items": added})\r
\r
\r
@admin_bp.route("/api/gallery/delete", methods=["POST"])\r
@login_required\r
def delete_gallery():\r
    gid = (request.get_json(silent=True) or {}).get("id")\r
    if not gid:\r
        return jsonify({"ok": False, "error": "id required"}), 400\r
    seasons = _load("gallery_seasons.json", [])\r
    item = None\r
    for season in seasons:\r
        photos = season.get("photos") or []\r
        found = next((x for x in photos if x.get("id") == gid), None)\r
        if found:\r
            item = found\r
            season["photos"] = [x for x in photos if x.get("id") != gid]\r
            break\r
\r
    if item:\r
        _save("gallery_seasons.json", seasons)\r
    else:\r
        gallery = _load("gallery.json", [])\r
        item = next((x for x in gallery if x.get("id") == gid), None)\r
        if not item:\r
            return jsonify({"ok": False, "error": "Not found"}), 404\r
        gallery = [x for x in gallery if x.get("id") != gid]\r
        _save("gallery.json", gallery)\r
\r
    rel = (item.get("path") or "").replace("/static/", "").replace("/", os.sep)\r
    abs_path = os.path.join(_BASE_DIR, "static", rel) if rel else ""\r
    if abs_path and os.path.isfile(abs_path):\r
        try:\r
            os.remove(abs_path)\r
        except OSError:\r
            pass\r
\r
    audit("gallery_delete", gid)\r
    return jsonify({"ok": True})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” GitHub Sync (background)\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/save-to-github", methods=["POST"])\r
@login_required\r
def api_save_to_github():\r
    """Trigger a background sync of the data directory to GitHub.\r
\r
    This runs the potentially slow git operations in a separate thread\r
    so the admin UI does not hang or time out. The sync result is\r
    recorded in the audit log by the worker.\r
    """\r
    body = request.get_json(silent=True) or {}\r
    detail = (body.get("detail") or "Admin manual save via UI").strip()\r
\r
    def _worker(d):\r
        try:\r
            res = sync_data_to_github(d)\r
            # Include the original detail string in audit so the UI can poll for this specific run.\r
            audit_detail = f"{d} | {json.dumps(res)[:700]}"\r
            audit("github_save", audit_detail)\r
        except Exception as exc:\r
            audit("github_save_error", str(exc)[:800])\r
\r
    t = threading.Thread(target=_worker, args=(detail,), daemon=True)\r
    t.start()\r
\r
    return jsonify({"ok": True, "started": True, "message": "Background sync started"}), 202\r
\r
\r
@admin_bp.route("/api/save-to-github-status", methods=["GET"])\r
@login_required\r
def api_save_to_github_status():\r
    """Return the latest github_save or github_save_error audit row.\r
\r
    If `nonce` query param is provided, find the latest audit row whose\r
    detail contains that nonce (this lets the UI poll for a specific run).\r
    """\r
    nonce = (request.args.get("nonce") or "").strip()\r
    try:\r
        conn = sqlite3.connect(_DB_PATH)\r
        if nonce:\r
            row = conn.execute(\r
                "SELECT ts, action, detail FROM audit_log WHERE detail LIKE ? ORDER BY id DESC LIMIT 1",\r
                (f"%{nonce}%",),\r
            ).fetchone()\r
        else:\r
            row = conn.execute(\r
                "SELECT ts, action, detail FROM audit_log WHERE action LIKE 'github_save%' OR action = 'github_save_error' ORDER BY id DESC LIMIT 1",\r
            ).fetchone()\r
        conn.close()\r
        if not row:\r
            return jsonify({"ok": True, "found": False})\r
        return jsonify({"ok": True, "found": True, "ts": row[0], "action": row[1], "detail": row[2]})\r
    except sqlite3.Error:\r
        return jsonify({"ok": False, "error": "DB error"}), 500\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” GitHub Sync\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/save-to-github", methods=["POST"])\r
@login_required\r
def api_save_to_github():\r
    """Save all carnival data to GitHub."""\r
    try:\r
        result = sync_data_to_github("Admin manual save via UI")\r
        if result.get("ok"):\r
            # Extract commit hash if available\r
            commit_hash = result.get("commit", "").strip()\r
            if not commit_hash and result.get("method") == "github_api":\r
                commit_hash = "api-sync"\r
            \r
            audit("github_save", f"Status: {result.get('reason', 'success')} | Commit: {commit_hash}")\r
            return jsonify({\r
                "ok": True,\r
                "commit_hash": commit_hash,\r
                "reason": result.get("reason", "success"),\r
                "skipped": result.get("skipped", False),\r
                "method": result.get("method", "git"),\r
                "updated": result.get("updated", [])\r
            })\r
        else:\r
            error_msg = result.get("error", "Unknown error")\r
            audit("github_save_error", error_msg)\r
            return jsonify({"ok": False, "error": error_msg}), 400\r
    except Exception as e:\r
        error_msg = str(e)\r
        audit("github_save_exception", error_msg)\r
        return jsonify({"ok": False, "error": error_msg}), 500\r


\r
def _empty_live():\r
    return json.loads(json.dumps(EMPTY_LIVE))\r
\r
# Set by init_audit_db()\r
_BASE_DIR = None\r
_DB_PATH = None\r
\r
\r
# ---------------------------------------------------------------------------\r
# Data helpers (mirror app.py so admin.py is import-safe on its own)\r
# ---------------------------------------------------------------------------\r
def _data_path(name):\r
    return os.path.join(_BASE_DIR, "data", name)\r
\r
\r
def _db_payload_name(name):\r
    return name if name.endswith(".json") else f"{name}.json"\r
\r
\r
def _load_from_db(name):\r
    if not _DB_PATH:\r
        return None\r
    try:\r
        conn = sqlite3.connect(_DB_PATH)\r
        row = conn.execute(\r
            "SELECT payload FROM data_store WHERE name = ?",\r
            (_db_payload_name(name),),\r
        ).fetchone()\r
        conn.close()\r
        if not row:\r
            return None\r
        return json.loads(row[0])\r
    except (sqlite3.Error, json.JSONDecodeError):\r
        return None\r
\r
\r
def _save_to_db(name, payload):\r
    if not _DB_PATH:\r
        return\r
    try:\r
        conn = sqlite3.connect(_DB_PATH)\r
        conn.execute(\r
            """INSERT INTO data_store (name, payload, updated_at)\r
               VALUES (?, ?, ?)\r
               ON CONFLICT(name) DO UPDATE SET\r
                 payload = excluded.payload,\r
                 updated_at = excluded.updated_at""",\r
            (\r
                _db_payload_name(name),\r
                json.dumps(payload, ensure_ascii=False),\r
                datetime.now().isoformat(timespec="seconds"),\r
            ),\r
        )\r
        conn.commit()\r
        conn.close()\r
    except sqlite3.Error:\r
        pass\r
\r
\r
def _load(name, default=None):\r
    try:\r
        with open(_data_path(name), "r", encoding="utf-8") as fh:\r
            return json.load(fh)\r
    except (FileNotFoundError, json.JSONDecodeError):\r
        return default\r
\r
\r
def _save(name, payload):\r
    path = _data_path(name)\r
    tmp = path + ".tmp"\r
    with open(tmp, "w", encoding="utf-8") as fh:\r
        json.dump(payload, fh, indent=2, ensure_ascii=False)\r
    os.replace(tmp, path)\r
    _save_to_db(name, payload)\r
    # Do not auto-push to GitHub on every single save â€” this caused\r
    # latency, race conditions and unexpected repo changes when many\r
    # admin actions happen in quick succession. Keep pushing manual\r
    # and controlled via the admin "Save to GitHub" button.\r
    # Enable automatic push by setting AUTO_PUSH_ON_SAVE=true in env.\r
    try:\r
        if os.environ.get("AUTO_PUSH_ON_SAVE", "false").lower() in {"1", "true", "yes"}:\r
            sync_data_to_github(name)\r
    except Exception:\r
        # Never let git-sync failures break admin writes.\r
        pass\r
\r
\r
def _load_player_tracker():\r
    return _load("player_tracker.json", {"teams": {}}) or {"teams": {}}\r
\r
\r
def _save_player_tracker(payload):\r
    if not isinstance(payload, dict):\r
        payload = {"teams": {}}\r
    payload.setdefault("teams", {})\r
    _save("player_tracker.json", payload)\r
    return payload\r
\r
\r
def _normalize_player_row(raw):\r
    played = _normalize_played_list(raw.get("played"))\r
    games = _normalize_games_list(raw.get("games"))\r
    player = {\r
        "id": (raw.get("id") or ("pt-" + uuid.uuid4().hex[:10])),\r
        "name": (raw.get("name") or "").strip(),\r
        "employee_id": (raw.get("employee_id") or "").strip(),\r
        "department": (raw.get("department") or "").strip(),\r
        "played": played,\r
        "games": games,\r
        "created_at": raw.get("created_at") or datetime.now().isoformat(timespec="seconds"),\r
        "updated_at": datetime.now().isoformat(timespec="seconds"),\r
    }\r
    return player\r
\r
\r
def _find_player_row(team_rows, player_id=None, employee_id=None):\r
    if not isinstance(team_rows, list):\r
        return None\r
    for row in team_rows:\r
        if player_id and row.get("id") == player_id:\r
            return row\r
        if employee_id and row.get("employee_id") == employee_id:\r
            return row\r
    return None\r
\r
\r
def _parse_player_bulk_line(line):\r
    parts = line.split("-")\r
    if len(parts) < 3:\r
        return None\r
    name = parts[0].strip()\r
    employee_id = parts[1].strip()\r
    department = "-".join(parts[2:]).strip()\r
    if not name or not employee_id or not department:\r
        return None\r
    return {"name": name, "employee_id": employee_id, "department": department}\r
\r
\r
def _normalize_played_list(raw):\r
    played = []\r
    if isinstance(raw, list):\r
        for idx in range(5):\r
            played.append(bool(raw[idx]) if idx < len(raw) else False)\r
    else:\r
        played = [False] * 5\r
    return played\r
\r
\r
def _normalize_games_list(raw):\r
    games = []\r
    if isinstance(raw, list):\r
        for idx in range(5):\r
            value = raw[idx] if idx < len(raw) else ""\r
            if isinstance(value, dict):\r
                value = value.get("name") or value.get("game") or ""\r
            games.append(str(value or "").strip())\r
    else:\r
        games = [""] * 5\r
    return games\r
\r
\r
def _ensure_player_data(team_id):\r
    data = _load_player_tracker()\r
    teams = data.setdefault("teams", {})\r
    teams.setdefault(team_id, [])\r
    return data\r
\r
\r
def _serialize_tracker_response(data):\r
    if not isinstance(data, dict):\r
        return {"teams": {}}\r
    data.setdefault("teams", {})\r
    return data\r
\r
\r
def _normalize_player_line(line):\r
    parts = line.split("-")\r
    if len(parts) < 3:\r
        return None\r
    name = parts[0].strip()\r
    employee_id = parts[1].strip()\r
    department = "-".join(parts[2:]).strip()\r
    if not name or not employee_id or not department:\r
        return None\r
    return {"name": name, "employee_id": employee_id, "department": department}\r
\r
\r
def _trim_team_tracker(data):\r
    if not isinstance(data, dict):\r
        return {"teams": {}}\r
    data.setdefault("teams", {})\r
    return data\r
\r
\r
def _team_tracker_safe(data):\r
    return _trim_team_tracker(data)\r
\r
\r
def _player_tracker_to_public(data):\r
    out = {"teams": {}}\r
    teams = data.get("teams") if isinstance(data.get("teams"), dict) else {}\r
    for team_id, rows in teams.items():\r
        out[team_id] = [\r
            {\r
                "id": row.get("id"),\r
                "name": row.get("name"),\r
                "employee_id": row.get("employee_id"),\r
                "department": row.get("department"),\r
                "played": _normalize_played_list(row.get("played")),\r
                "games": _normalize_games_list(row.get("games")),\r
            }\r
            for row in (rows or [])\r
        ]\r
    return {"teams": out}\r
\r
\r
def _update_player_row(team_rows, player_id, updates):\r
    row = _find_player_row(team_rows, player_id=player_id)\r
    if not row:\r
        return None\r
    if "name" in updates and isinstance(updates["name"], str):\r
        row["name"] = updates["name"].strip()\r
    if "employee_id" in updates and isinstance(updates["employee_id"], str):\r
        row["employee_id"] = updates["employee_id"].strip()\r
    if "department" in updates and isinstance(updates["department"], str):\r
        row["department"] = updates["department"].strip()\r
    if "played" in updates and isinstance(updates["played"], list):\r
        row["played"] = _normalize_played_list(updates["played"])\r
    if "games" in updates and isinstance(updates["games"], list):\r
        row["games"] = _normalize_games_list(updates["games"])\r
    if "index" in updates and isinstance(updates["index"], int) and 0 <= updates["index"] < 5:\r
        row["played"] = _normalize_played_list(row.get("played", []))\r
        row["games"] = _normalize_games_list(row.get("games", []))\r
        row["played"][updates["index"]] = bool(updates.get("checked", False))\r
        if "game" in updates:\r
            row["games"][updates["index"]] = str(updates.get("game") or "").strip()\r
    row["updated_at"] = datetime.now().isoformat(timespec="seconds")\r
    return row\r
\r
\r
def _public_player_row(row):\r
    return {\r
        "id": row.get("id"),\r
        "name": row.get("name"),\r
        "employee_id": row.get("employee_id"),\r
        "department": row.get("department"),\r
        "played": _normalize_played_list(row.get("played")),\r
        "games": _normalize_games_list(row.get("games")),\r
    }\r
\r
\r
def _public_player_tracker(data):\r
    return {"teams": {k: [_public_player_row(r) for r in (v or [])] for k, v in (data.get("teams") or {}).items()}}\r
\r
\r
def _save_player_tracker_payload(data):\r
    _save_player_tracker(data)\r
    return data\r
\r
\r
def _normalize_tracker_data(data):\r
    if not isinstance(data, dict):\r
        return {"teams": {}}\r
    cleaned = {"teams": {}}\r
    for team_id, players in (data.get("teams") or {}).items():\r
        cleaned[team_id] = [\r
            _normalize_player_row(player if isinstance(player, dict) else {})\r
            for player in (players or [])\r
        ]\r
    return cleaned\r
\r
\r
def _clean_tracker_data(data):\r
    data = _normalize_tracker_data(data)\r
    _save_player_tracker(data)\r
    return data\r
\r
\r
def _tracker_team_rows(data, team_id):\r
    return (data.get("teams") or {}).get(team_id, [])\r
\r
\r
def _is_valid_tracker_team(team_id):\r
    return team_id in VALID_TEAM_IDS\r
\r
\r
def _trim_tracker_input(players):\r
    if not isinstance(players, list):\r
        return []\r
    out = []\r
    for raw in players:\r
        if not isinstance(raw, dict):\r
            continue\r
        if not raw.get("name") or not raw.get("employee_id"):\r
            continue\r
        out.append(_normalize_player_row(raw))\r
    return out\r
\r
\r
\r
def _player_tracker_meta(team_rows):\r
    return {\r
        "count": len(team_rows),\r
        "completed": sum(1 for row in team_rows if sum(bool(x) for x in row.get("played", [])) >= 5),\r
    }\r
\r
\r
def _player_tracker_record(team_rows, raw):\r
    row = _find_player_row(team_rows, employee_id=raw.get("employee_id"))\r
    if row:\r
        row.update({\r
            "name": raw.get("name", row.get("name")),\r
            "department": raw.get("department", row.get("department")),\r
            "updated_at": datetime.now().isoformat(timespec="seconds"),\r
        })\r
        return row\r
    new = _normalize_player_row(raw)\r
    team_rows.append(new)\r
    return new\r
\r
\r
def _player_tracker_for_public(data):\r
    return {"teams": {team_id: [_public_player_row(row) for row in rows] for team_id, rows in (data.get("teams") or {}).items()}}\r
\r
\r
\r
def _clean_tracker_line(line):\r
    return _normalize_player_line(line) if isinstance(line, str) else None\r
\r
\r
def _parse_tracker_bulk(lines):\r
    out = []\r
    if not isinstance(lines, list):\r
        return out\r
    for raw in lines:\r
        if isinstance(raw, str):\r
            item = _clean_tracker_line(raw)\r
            if item:\r
                out.append(item)\r
    return out\r
\r
\r
def _tracker_response(data):\r
    return _player_tracker_for_public(data)\r
\r
\r
\r
def _tracker_lookup(team_id):\r
    data = _load_player_tracker()\r
    return (data.get("teams") or {}).get(team_id, [])\r
\r
\r
def _tracker_full():\r
    return _player_tracker_for_public(_load_player_tracker())\r
\r
\r
def _tracker_team(team_id):\r
    data = _load_player_tracker()\r
    rows = _tracker_lookup(team_id)\r
    return {"team_id": team_id, "players": [_public_player_row(r) for r in rows]}\r
\r
\r
\r
def _tracker_row_exists(team_rows, employee_id):\r
    return _find_player_row(team_rows, employee_id=employee_id) is not None\r
\r
\r
\r
def _tracker_update_or_add(team_rows, raw):\r
    existing = _find_player_row(team_rows, employee_id=raw.get("employee_id"))\r
    if existing:\r
        existing["name"] = raw.get("name", existing.get("name"))\r
        existing["department"] = raw.get("department", existing.get("department"))\r
        existing["updated_at"] = datetime.now().isoformat(timespec="seconds")\r
        return existing\r
    new = _normalize_player_row(raw)\r
    team_rows.append(new)\r
    return new\r
\r
\r
def _match_key(row):\r
    return row.get("match_id") or row.get("id") or row.get("event_id")\r
\r
\r
def _new_match_id(event_id):\r
    return f"{event_id}-{uuid.uuid4().hex[:8]}"\r
\r
\r
def _normal_scores(raw_scores):\r
    raw_scores = raw_scores if isinstance(raw_scores, dict) else {}\r
    return {\r
        "creators": int(raw_scores.get("creators", 0) or 0),\r
        "dominators": int(raw_scores.get("dominators", 0) or 0),\r
        "royals": int(raw_scores.get("royals", 0) or 0),\r
    }\r
\r
\r
def _sync_live_index(scores):\r
    matches = scores.get("live_matches") if isinstance(scores.get("live_matches"), list) else []\r
    completed = scores.get("completed") if isinstance(scores.get("completed"), list) else []\r
\r
    clean_matches = []\r
    for m in matches:\r
        if not isinstance(m, dict) or not m.get("event_id"):\r
            continue\r
        m.setdefault("status", "upcoming")\r
        m.setdefault("match_id", f"{m['event_id']}-{m.get('status', 'upcoming')}")\r
        m.setdefault("commentary", [])\r
        m.setdefault("details", {})\r
        m.setdefault("scores", {"creators": 0, "dominators": 0, "royals": 0})\r
        if m.get("status") != "completed":\r
            clean_matches.append(m)\r
\r
    clean_completed = []\r
    for c in completed:\r
        if not isinstance(c, dict) or not c.get("event_id"):\r
            continue\r
        c["status"] = "completed"\r
        c.setdefault("match_id", f"{c['event_id']}-completed")\r
        c.setdefault("details", {})\r
        c.setdefault("scores", {"creators": 0, "dominators": 0, "royals": 0})\r
        clean_completed.append(c)\r
\r
    scores["live_matches"] = clean_matches\r
    scores["completed"] = clean_completed\r
    first_live = next((m for m in clean_matches if m.get("status") == "live"), clean_matches[0] if clean_matches else None)\r
    scores["active_event"] = first_live.get("event_id") if first_live and first_live.get("status") == "live" else None\r
    scores["live"] = dict(first_live) if first_live else _empty_live()\r
    return scores\r
\r
\r
def _find_match(scores, match_id=None, event_id=None, status=None):\r
    rows = []\r
    rows.extend(scores.get("live_matches") or [])\r
    rows.extend(scores.get("completed") or [])\r
    for row in rows:\r
        if match_id and _match_key(row) == match_id:\r
            return dict(row)\r
        if not match_id and event_id and row.get("event_id") == event_id and (not status or row.get("status") == status):\r
            return dict(row)\r
    return None\r
\r
\r
def _build_match(body, existing=None, partial=False):\r
    existing = dict(existing or {})\r
    events = {e["id"]: e for e in _load("events.json", [])}\r
    formats = _load("match_formats.json", {})\r
\r
    event_id = (body.get("event_id") or existing.get("event_id") or "").strip()\r
    if not event_id:\r
        return None, "event_id required"\r
    if event_id not in events:\r
        return None, "Unknown event"\r
\r
    status = body.get("status", existing.get("status", "upcoming"))\r
    if status not in VALID_STATUSES:\r
        return None, "Invalid status"\r
\r
    allowed_rounds = (formats.get(event_id, {}) or {}).get("rounds") or []\r
    round_label = (body.get("round", existing.get("round", "")) or "").strip()\r
    if allowed_rounds and round_label and round_label not in allowed_rounds:\r
        return None, "Invalid round for this sport"\r
    if not round_label and allowed_rounds and not partial:\r
        round_label = allowed_rounds[0]\r
\r
    team_a = body.get("team_a", existing.get("team_a"))\r
    team_b = body.get("team_b", existing.get("team_b"))\r
    if team_a and team_a not in VALID_TEAM_IDS:\r
        return None, "Invalid team A"\r
    if team_b and team_b not in VALID_TEAM_IDS:\r
        return None, "Invalid team B"\r
    if team_a and team_b and team_a == team_b:\r
        return None, "Teams must be different"\r
\r
    try:\r
        score_a = int(body.get("score_a", existing.get("score_a", 0)) or 0)\r
        score_b = int(body.get("score_b", existing.get("score_b", 0)) or 0)\r
    except (TypeError, ValueError):\r
        return None, "Scores must be numbers"\r
\r
    match = dict(existing)\r
    now = datetime.now().isoformat(timespec="seconds")\r
    match.update({\r
        "match_id": existing.get("match_id") or body.get("match_id") or _new_match_id(event_id),\r
        "event_id": event_id,\r
        "event_name": events[event_id]["name"],\r
        "date": events[event_id].get("date", ""),\r
        "status": status,\r
        "round": round_label,\r
        "team_a": team_a or None,\r
        "team_b": team_b or None,\r
        "score_a": max(0, score_a),\r
        "score_b": max(0, score_b),\r
        "scores": _normal_scores(body.get("scores", existing.get("scores", {}))),\r
        "details": body.get("details") if isinstance(body.get("details"), dict) else (existing.get("details") or {}),\r
        "commentary": existing.get("commentary") or [],\r
        "created_at": existing.get("created_at") or now,\r
        "updated_at": now,\r
    })\r
    return match, None\r
\r
\r
def _save_match(match):\r
    scores = _sync_live_index(_load("scores.json", {}))\r
    match_id = _match_key(match)\r
    scores["live_matches"] = [m for m in scores.get("live_matches", []) if _match_key(m) != match_id]\r
    scores["completed"] = [m for m in scores.get("completed", []) if _match_key(m) != match_id]\r
\r
    if match.get("status") == "completed":\r
        scores["completed"].insert(0, dict(match))\r
    else:\r
        scores["live_matches"].append(dict(match))\r
\r
    scores = _sync_live_index(scores)\r
    _save("scores.json", scores)\r
    return scores\r
\r
\r
def _delete_match(match_id=None, event_id=None, status=None):\r
    scores = _sync_live_index(_load("scores.json", {}))\r
\r
    def keep(row):\r
        if match_id:\r
            return _match_key(row) != match_id\r
        if event_id and row.get("event_id") == event_id and (not status or row.get("status") == status):\r
            return False\r
        return True\r
\r
    scores["live_matches"] = [m for m in scores.get("live_matches", []) if keep(m)]\r
    scores["completed"] = [m for m in scores.get("completed", []) if keep(m)]\r
    scores = _sync_live_index(scores)\r
    _save("scores.json", scores)\r
    return scores\r
\r
\r
def _enrich_match(row, teams):\r
    out = dict(row)\r
    out["match_id"] = _match_key(out)\r
    if out.get("team_a") in teams:\r
        out["team_a_name"] = teams[out["team_a"]]["name"]\r
    if out.get("team_b") in teams:\r
        out["team_b_name"] = teams[out["team_b"]]["name"]\r
    return out\r
\r
\r
# ---------------------------------------------------------------------------\r
# Audit log (SQLite)\r
# ---------------------------------------------------------------------------\r
def init_audit_db(base_dir):\r
    """Called once at app start. Creates carnival.db tables and seeds durable data."""\r
    global _BASE_DIR, _DB_PATH\r
    _BASE_DIR = base_dir\r
    _DB_PATH = os.path.join(base_dir, "carnival.db")\r
    conn = sqlite3.connect(_DB_PATH)\r
    conn.execute(\r
        """CREATE TABLE IF NOT EXISTS audit_log (\r
               id        INTEGER PRIMARY KEY AUTOINCREMENT,\r
               ts        TEXT NOT NULL,\r
               action    TEXT NOT NULL,\r
               detail    TEXT\r
           )"""\r
    )\r
    conn.execute(\r
        """CREATE TABLE IF NOT EXISTS data_store (\r
               name       TEXT PRIMARY KEY,\r
               payload    TEXT NOT NULL,\r
               updated_at TEXT NOT NULL\r
           )"""\r
    )\r
    data_dir = os.path.join(base_dir, "data")\r
    try:\r
        for filename in os.listdir(data_dir):\r
            if not filename.endswith(".json"):\r
                continue\r
            exists = conn.execute("SELECT 1 FROM data_store WHERE name = ?", (filename,)).fetchone()\r
            if exists:\r
                continue\r
            with open(os.path.join(data_dir, filename), "r", encoding="utf-8") as fh:\r
                payload = json.load(fh)\r
            conn.execute(\r
                "INSERT INTO data_store (name, payload, updated_at) VALUES (?, ?, ?)",\r
                (filename, json.dumps(payload, ensure_ascii=False), datetime.now().isoformat(timespec="seconds")),\r
            )\r
    except (OSError, json.JSONDecodeError):\r
        pass\r
    conn.commit()\r
    conn.close()\r
\r
\r
def audit(action, detail=""):\r
    try:\r
        conn = sqlite3.connect(_DB_PATH)\r
        conn.execute(\r
            "INSERT INTO audit_log (ts, action, detail) VALUES (?, ?, ?)",\r
            (datetime.now().isoformat(timespec="seconds"), action, detail),\r
        )\r
        conn.commit()\r
        conn.close()\r
    except sqlite3.Error:\r
        pass  # never let logging break a write\r
\r
\r
# ---------------------------------------------------------------------------\r
# Auth\r
# ---------------------------------------------------------------------------\r
def login_required(view):\r
    @wraps(view)\r
    def wrapped(*args, **kwargs):\r
        if not session.get("admin"):\r
            # API calls get JSON 401; page loads get redirected to login.\r
            if request.path.startswith("/admin/api/"):\r
                return jsonify({"ok": False, "error": "Not authenticated"}), 401\r
            return redirect(url_for("admin.login"))\r
        return view(*args, **kwargs)\r
    return wrapped\r
\r
\r
@admin_bp.route("/", methods=["GET", "POST"])\r
def login():\r
    if session.get("admin"):\r
        return redirect(url_for("admin.dashboard"))\r
    error = None\r
    if request.method == "POST":\r
        username_raw = (request.form.get("username") or "").strip()\r
        username_key = username_raw.lower()\r
        password = request.form.get("password")\r
        if username_key in ALLOWED_ADMIN_USERS and password == ADMIN_PASSWORD:\r
            session["admin"] = True\r
            session["admin_user"] = ALLOWED_ADMIN_USERS[username_key]\r
            audit("login", f"{session['admin_user']} logged in")\r
            return redirect(url_for("admin.dashboard"))\r
        error = "Invalid username or password."\r
    return render_template("admin/login.html", error=error)\r
\r
\r
@admin_bp.route("/logout")\r
def logout():\r
    session.pop("admin", None)\r
    session.pop("admin_user", None)\r
    return redirect(url_for("admin.login"))\r
\r
\r
@admin_bp.route("/dashboard")\r
@login_required\r
def dashboard():\r
    events = _load("events.json", [])\r
    teams = _load("teams.json", [])\r
    announcements = _load("announcements.json", [])\r
    awards = _load("awards.json", {})\r
    scores = _load("scores.json", {})\r
    gallery_seasons = _load("gallery_seasons.json", [])\r
    season4 = next((s for s in gallery_seasons if s.get("id") == "season-4"), None)\r
    gallery = (season4 or {}).get("photos") or _load("gallery.json", [])\r
    champions = _load("champions.json", [])\r
    match_formats = _load("match_formats.json", {})\r
    audit_rows = _recent_audit()\r
    return render_template(\r
        "admin/dashboard.html",\r
        events=events, teams=teams, announcements=announcements,\r
        awards=awards, scores=scores, gallery=gallery, champions=champions, match_formats=match_formats,\r
        audit_rows=audit_rows,\r
    )\r
\r
\r
def _recent_audit(limit=25):\r
    try:\r
        conn = sqlite3.connect(_DB_PATH)\r
        rows = conn.execute(\r
            "SELECT ts, action, detail FROM audit_log ORDER BY id DESC LIMIT ?",\r
            (limit,),\r
        ).fetchall()\r
        conn.close()\r
        return [{"ts": r[0], "action": r[1], "detail": r[2]} for r in rows]\r
    except sqlite3.Error:\r
        return []\r
\r
\r

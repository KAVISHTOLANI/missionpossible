"""\r
Mission Possible 2026 â€” Admin blueprint.\r
\r
Handles:\r
  - password login (session cookie)\r
  - all write endpoints (announcements, live scores, standings, awards, rules, logos)\r
  - SQLite audit log of every admin action\r
\r
Public read APIs live in app.py. This module only mutates the JSON data files.\r
The admin password is read from the CARNIVAL_ADMIN_PASSWORD env var, falling\r
back to "carnival2026" for local development.\r
"""\r
import json\r
import os\r
import sqlite3\r
import uuid\r
from datetime import datetime\r
from functools import wraps\r
import threading\r
\r
from flask import (\r
    Blueprint, render_template, request, redirect, url_for,\r
    session, jsonify, current_app,\r
)\r
from werkzeug.utils import secure_filename\r
from git_sync import sync_data_to_github\r
\r
admin_bp = Blueprint("admin", __name__, url_prefix="/admin")\r
\r
ADMIN_PASSWORD = os.environ.get("CARNIVAL_ADMIN_PASSWORD", "carnival2026")\r

@admin_bp.route("/api/announcements/add", methods=["POST"])\r
@login_required\r
def add_announcement():\r
    body = request.get_json(silent=True) or {}\r
    title = (body.get("title") or "").strip()\r
    text = (body.get("body") or "").strip()\r
    tag = body.get("tag") if body.get("tag") in VALID_TAGS else "Info"\r
    if not title or not text:\r
        return jsonify({"ok": False, "error": "Title and body required"}), 400\r
    items = _load("announcements.json", [])\r
    item = {\r
        "id": "ann-" + uuid.uuid4().hex[:8],\r
        "title": title,\r
        "date": datetime.now().strftime("%Y-%m-%d"),\r
        "body": text,\r
        "tag": tag,\r
    }\r
    items.insert(0, item)\r
    _save("announcements.json", items)\r
    audit("announcement_add", title)\r
    return jsonify({"ok": True, "item": item})\r
\r
\r
@admin_bp.route("/api/announcements/delete", methods=["POST"])\r
@login_required\r
def delete_announcement():\r
    ann_id = (request.get_json(silent=True) or {}).get("id")\r
    items = _load("announcements.json", [])\r
    new_items = [a for a in items if a.get("id") != ann_id]\r
    _save("announcements.json", new_items)\r
    audit("announcement_delete", ann_id or "")\r
    return jsonify({"ok": True})\r

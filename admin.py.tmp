@login_required\r
def admin_player_tracker():\r
    data = _load_player_tracker()\r
    return jsonify({"ok": True, "tracker": _player_tracker_for_public(data)})\r
\r
\r
@admin_bp.route("/api/player-tracker/bulk-add", methods=["POST"])\r
@login_required\r
def admin_player_tracker_bulk_add():\r
    body = request.get_json(silent=True) or {}\r
    team_id = (body.get("team") or "").strip()\r
    lines = body.get("lines") if isinstance(body.get("lines"), list) else []\r
    if team_id not in VALID_TEAM_IDS:\r
        return jsonify({"ok": False, "error": "Unknown team"}), 400\r
    if not lines:\r
        return jsonify({"ok": False, "error": "Add at least one player line"}), 400\r
\r
    data = _load_player_tracker()\r
    team_rows = data.setdefault("teams", {}).setdefault(team_id, [])\r
    added = 0\r
    for raw_line in lines:\r
        if not isinstance(raw_line, str):\r
            continue\r
        parsed = _parse_player_bulk_line(raw_line)\r
        if not parsed:\r
            continue\r
        existing = _find_player_row(team_rows, employee_id=parsed["employee_id"])\r
        if existing:\r
            existing["name"] = parsed["name"]\r
            existing["department"] = parsed["department"]\r
            existing["updated_at"] = datetime.now().isoformat(timespec="seconds")\r
        else:\r
            team_rows.append(_normalize_player_row(parsed))\r
        added += 1\r
\r
    _save_player_tracker(data)\r
    audit("player_tracker_bulk_add", f"{team_id} {added} players")\r
    return jsonify({"ok": True, "tracker": _player_tracker_for_public(data), "added": added})\r
\r
\r
@admin_bp.route("/api/player-tracker/update-played", methods=["POST"])\r
@login_required\r
def admin_player_tracker_update_played():\r
    body = request.get_json(silent=True) or {}\r
    team_id = (body.get("team") or "").strip()\r
    player_id = (body.get("player_id") or "").strip()\r
    try:\r
        index = int(body.get("index"))\r
    except (TypeError, ValueError):\r
        return jsonify({"ok": False, "error": "Invalid index"}), 400\r
    checked = bool(body.get("checked"))\r
\r
    if team_id not in VALID_TEAM_IDS:\r
        return jsonify({"ok": False, "error": "Unknown team"}), 400\r
    if not player_id:\r
        return jsonify({"ok": False, "error": "player_id is required"}), 400\r
    if index < 0 or index > 4:\r
        return jsonify({"ok": False, "error": "Index must be between 0 and 4"}), 400\r
\r
    data = _load_player_tracker()\r
    team_rows = data.setdefault("teams", {}).get(team_id, [])\r
    row = _find_player_row(team_rows, player_id=player_id)\r
    if not row:\r
        return jsonify({"ok": False, "error": "Player not found"}), 404\r
\r
    row["played"] = _normalize_played_list(row.get("played", []))\r
    row["games"] = _normalize_games_list(row.get("games", []))\r
    row["played"][index] = checked\r
    if "game" in body:\r
        row["games"][index] = str(body.get("game") or "").strip()\r
    row["updated_at"] = datetime.now().isoformat(timespec="seconds")\r
\r
    _save_player_tracker(data)\r
    audit("player_tracker_update_played", f"{team_id} {player_id} game {index + 1} {checked}")\r
    return jsonify({"ok": True, "player": _public_player_row(row)})\r
\r
\r
@admin_bp.route("/api/player-tracker/delete", methods=["POST"])\r
@login_required\r
def admin_player_tracker_delete():\r
    body = request.get_json(silent=True) or {}\r
    team_id = (body.get("team") or "").strip()\r
    player_id = (body.get("player_id") or "").strip()\r
\r
    if team_id not in VALID_TEAM_IDS:\r
        return jsonify({"ok": False, "error": "Unknown team"}), 400\r
    if not player_id:\r
        return jsonify({"ok": False, "error": "player_id is required"}), 400\r
\r
    data = _load_player_tracker()\r
    team_rows = data.setdefault("teams", {}).get(team_id, [])\r
    before = len(team_rows)\r
    data["teams"][team_id] = [row for row in team_rows if row.get("id") != player_id]\r
    if len(data["teams"][team_id]) == before:\r
        return jsonify({"ok": False, "error": "Player not found"}), 404\r
\r
    _save_player_tracker(data)\r
    audit("player_tracker_delete", f"{team_id} {player_id}")\r
    return jsonify({"ok": True, "tracker": _player_tracker_for_public(data)})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Live scores\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/live/update", methods=["POST"])\r
@login_required\r
def update_live():\r
    body = request.get_json(silent=True) or {}\r
    lookup = _sync_live_index(_load("scores.json", {}))\r
    existing = None\r
    if body.get("match_id"):\r
        existing = _find_match(lookup, match_id=body.get("match_id"))\r
    elif not body.get("append_to_live_matches"):\r
        existing = _find_match(lookup, event_id=body.get("event_id"))\r
\r
    match, error = _build_match(body, existing=existing)\r
    if error:\r
        return jsonify({"ok": False, "error": error}), 400\r
\r
    scores = _save_match(match)\r
    audit(\r
        "live_update",\r
        f"{match['event_id']} {match['status']} {match['round']} {match.get('team_a')} vs {match.get('team_b')} {match['score_a']}-{match['score_b']}",\r
    )\r
    return jsonify({"ok": True, "match": match, "live_matches": scores.get("live_matches", []), "live": scores.get("live", {})})\r
\r
\r
@admin_bp.route("/api/live/commentary", methods=["POST"])\r
@login_required\r
def add_commentary():\r
    body = request.get_json(silent=True) or {}\r
    text = (body.get("text") or "").strip()\r
    match_id = (body.get("match_id") or "").strip()\r
    event_id = (body.get("event_id") or "").strip()\r
    if not text:\r
        return jsonify({"ok": False, "error": "Empty commentary"}), 400\r
    scores = _sync_live_index(_load("scores.json", {}))\r
    matches = scores.setdefault("live_matches", [])\r
    if not isinstance(matches, list):\r
        matches = []\r
    live = None\r
    if match_id:\r
        live = next((m for m in matches if _match_key(m) == match_id), None)\r
    if not live and event_id:\r
        live = next((m for m in matches if m.get("event_id") == event_id), None)\r
    if not live:\r
        live = next((m for m in matches if m.get("status") == "live"), None)\r
    if not live:\r
        return jsonify({"ok": False, "error": "No live scoreboard found for commentary"}), 400\r
    entry = {"time": datetime.now().strftime("%H:%M"), "text": text}\r
    live.setdefault("commentary", []).insert(0, entry)\r
    if not event_id:\r
        event_id = live.get("event_id") or ""\r
    scores["live"] = dict(live)\r
    scores["active_event"] = event_id if live.get("status") == "live" else scores.get("active_event")\r
    _save("scores.json", scores)\r
    audit("commentary_add", text[:60])\r
    return jsonify({"ok": True, "entry": entry, "event_id": event_id})\r
\r
\r
@admin_bp.route("/api/live/clear", methods=["POST"])\r
@login_required\r
def clear_live_record():\r
    body = request.get_json(silent=True) or {}\r
    event_id = body.get("event_id")\r
    scores = _load("scores.json", {})\r
    if event_id:\r
        scores["completed"] = [\r
            row for row in (scores.get("completed") or [])\r
            if row.get("event_id") != event_id\r
        ]\r
    matches = scores.setdefault("live_matches", [])\r
    if not isinstance(matches, list):\r
        matches = []\r
    if event_id:\r
        matches = [m for m in matches if m.get("event_id") != event_id]\r
    else:\r
        matches = []\r
    scores["live_matches"] = matches\r
    first_live = next((m for m in matches if m.get("status") == "live"), matches[0] if matches else None)\r
    scores["active_event"] = first_live.get("event_id") if first_live and first_live.get("status") == "live" else None\r
    scores["live"] = dict(first_live) if first_live else {\r
        "event_id": None,\r
        "event_name": "",\r
        "status": "upcoming",\r
        "round": "",\r
        "team_a": None,\r
        "team_b": None,\r
        "score_a": 0,\r
        "score_b": 0,\r
        "scores": {"creators": 0, "dominators": 0, "royals": 0},\r
        "commentary": [],\r
        "details": {},\r
    }\r
\r
    _save("scores.json", scores)\r
    audit("live_clear", event_id or "all")\r
    return jsonify({"ok": True, "live_matches": scores.get("live_matches", []), "completed": scores.get("completed", [])})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Comprehensive Live Matches Management API\r
# ---------------------------------------------------------------------------\r
\r
@admin_bp.route("/api/live/list", methods=["GET"])\r
@login_required\r
def list_live_matches():\r
    """Get all live, upcoming, and archived matches with optional status filter."""\r
    status_filter = request.args.get("status", "").lower()\r
    scores = _sync_live_index(_load("scores.json", {}))\r
    teams = {t["id"]: t for t in _load("teams.json", [])}\r
    all_matches = [_enrich_match(m, teams) for m in (scores.get("live_matches") or [])]\r
    all_matches.extend(_enrich_match(m, teams) for m in (scores.get("completed") or []))\r
\r
    if status_filter:\r
        all_matches = [m for m in all_matches if m.get("status") == status_filter]\r
\r
    status_order = {"live": 0, "upcoming": 1, "completed": 2}\r
    all_matches.sort(key=lambda m: (status_order.get(m.get("status"), 3), m.get("event_name", ""), m.get("round", "")))\r
    return jsonify({"ok": True, "matches": all_matches, "total": len(all_matches)})\r
\r
\r
@admin_bp.route("/api/live/matches", methods=["GET"])\r
@login_required\r
def api_live_matches_get():\r
    return list_live_matches()\r

@admin_bp.route("/api/live/matches/<match_id>", methods=["PUT", "PATCH"])\r
@login_required\r
def api_live_matches_update(match_id):\r
    body = request.get_json(silent=True) or {}\r
    scores = _sync_live_index(_load("scores.json", {}))\r
    existing = _find_match(scores, match_id=match_id)\r
    if not existing:\r
        return jsonify({"ok": False, "error": "Match not found"}), 404\r
    body["match_id"] = match_id\r
    match, error = _build_match(body, existing=existing, partial=request.method == "PATCH")\r
    if error:\r
        return jsonify({"ok": False, "error": error}), 400\r
    scores = _save_match(match)\r
    audit("live_match_update", f"{match_id} {match['status']}")\r
    return jsonify({"ok": True, "match": match, "live": scores.get("live", {})})\r
\r
\r
@admin_bp.route("/api/live/matches/<match_id>", methods=["DELETE"])\r
@login_required\r
def api_live_matches_delete(match_id):\r
    scores = _sync_live_index(_load("scores.json", {}))\r
    if not _find_match(scores, match_id=match_id):\r
        return jsonify({"ok": False, "error": "Match not found"}), 404\r
    _delete_match(match_id=match_id)\r
    audit("live_match_delete", match_id)\r
    return jsonify({"ok": True, "message": "Match deleted"})\r
\r
\r
@admin_bp.route("/api/live/matches/<match_id>/status", methods=["POST", "PATCH"])\r
@login_required\r
def api_live_matches_status(match_id):\r
    body = request.get_json(silent=True) or {}\r
    new_status = body.get("new_status") or body.get("status")\r
    if new_status not in VALID_STATUSES:\r
        return jsonify({"ok": False, "error": "Invalid status"}), 400\r
    scores = _sync_live_index(_load("scores.json", {}))\r
    existing = _find_match(scores, match_id=match_id)\r
    if not existing:\r
        return jsonify({"ok": False, "error": "Match not found"}), 404\r
    existing["status"] = new_status\r
    match, error = _build_match(existing, existing=existing, partial=True)\r
    if error:\r
        return jsonify({"ok": False, "error": error}), 400\r
    scores = _save_match(match)\r
    audit("live_match_status", f"{match_id} -> {new_status}")\r
    return jsonify({"ok": True, "match": match, "live": scores.get("live", {})})\r
\r
\r
@admin_bp.route("/api/live/delete", methods=["POST"])\r
@login_required\r
def delete_live_match():\r
    """Delete a match from live_matches or completed list."""\r
    body = request.get_json(silent=True) or {}\r
    match_id = body.get("match_id")\r
    event_id = body.get("event_id")\r
    status = body.get("status", "upcoming")\r
\r
    if not match_id and not event_id:\r
        return jsonify({"ok": False, "error": "match_id or event_id required"}), 400\r
\r
    _delete_match(match_id=match_id, event_id=event_id, status=status if not match_id else None)\r
    audit("live_delete", match_id or f"{event_id} ({status})")\r
    return jsonify({"ok": True, "message": "Match deleted"})\r
\r
\r
@admin_bp.route("/api/live/move-status", methods=["POST"])\r
@login_required\r
def move_match_status():\r
    """Move a match from one status to another (upcoming <-> live <-> completed)."""\r
    body = request.get_json(silent=True) or {}\r
    match_id = body.get("match_id")\r
    event_id = body.get("event_id")\r
    new_status = body.get("new_status", "upcoming")\r
\r
    if not match_id and not event_id:\r
        return jsonify({"ok": False, "error": "match_id or event_id required"}), 400\r
    if new_status not in VALID_STATUSES:\r
        return jsonify({"ok": False, "error": "Invalid status"}), 400\r
\r
    scores = _sync_live_index(_load("scores.json", {}))\r
    match = _find_match(scores, match_id=match_id, event_id=event_id)\r
    if not match:\r
        return jsonify({"ok": False, "error": "Match not found"}), 400\r
\r
    match["status"] = new_status\r
    match, error = _build_match(match, existing=match, partial=True)\r
    if error:\r
        return jsonify({"ok": False, "error": error}), 400\r
    _save_match(match)\r
    audit("live_move_status", f"{_match_key(match)} -> {new_status}")\r
    return jsonify({"ok": True, "match": match, "message": f"Match moved to {new_status}"})\r
\r
\r
@admin_bp.route("/api/live/quick-update", methods=["POST"])\r
@login_required\r
def quick_update_scores():\r
    """Quick update scores for a match without modifying other fields."""\r
    body = request.get_json(silent=True) or {}\r
    match_id = body.get("match_id")\r
    event_id = body.get("event_id")\r
\r
    if not match_id and not event_id:\r
        return jsonify({"ok": False, "error": "match_id or event_id required"}), 400\r
    \r
    try:\r
        score_a = int(body.get("score_a", 0) or 0)\r
        score_b = int(body.get("score_b", 0) or 0)\r
    except (TypeError, ValueError):\r
        return jsonify({"ok": False, "error": "Scores must be numbers"}), 400\r
    \r
    scores = _sync_live_index(_load("scores.json", {}))\r
    match = _find_match(scores, match_id=match_id, event_id=event_id)\r
    if not match:\r
        return jsonify({"ok": False, "error": "Match not found"}), 404\r
\r
    match["score_a"] = max(0, score_a)\r
    match["score_b"] = max(0, score_b)\r
    match, error = _build_match(match, existing=match, partial=True)\r
    if error:\r
        return jsonify({"ok": False, "error": error}), 400\r
    _save_match(match)\r
    audit("live_quick_update", f"{_match_key(match)} {score_a}-{score_b}")\r
    return jsonify({"ok": True, "message": "Scores updated"})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Standings\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/standings/update", methods=["POST"])\r
@login_required\r
def update_standings():\r
    body = request.get_json(silent=True) or {}\r
    team_id = body.get("team")\r
    entry_id = (body.get("entry_id") or "").strip()\r
    event_name = (body.get("event") or "").strip()\r
    try:\r
        points = int(body.get("points", 0) or 0)\r
    except (TypeError, ValueError):\r
        return jsonify({"ok": False, "error": "Points must be a number"}), 400\r
    penalty = bool(body.get("penalty"))\r
    note = (body.get("note") or "").strip()\r
\r
    if team_id not in VALID_TEAM_IDS:\r
        return jsonify({"ok": False, "error": "Unknown team"}), 400\r
\r
    standings = _load("standings.json", {"teams": {}})\r
    teams = standings.get("teams", {})\r
    if team_id not in teams:\r
        return jsonify({"ok": False, "error": "Team not in standings"}), 400\r
\r
    _ensure_standings_entry_ids(standings)\r
\r
    row = {\r
        "id": entry_id or ("st-" + uuid.uuid4().hex[:10]),\r
        "event": event_name,\r
        "points": -points if penalty else points,\r
        "type": "penalty" if penalty else "points",\r
        "note": note,\r
    }\r
\r
    if entry_id:\r
        found = False\r
        for tid, t in teams.items():\r
            rows = t.setdefault("event_breakdown", [])\r
            for idx, existing in enumerate(rows):\r
                if existing.get("id") == entry_id:\r
                    found = True\r
                    if tid == team_id:\r
                        rows[idx] = row\r
                    else:\r
                        rows.pop(idx)\r
                        teams[team_id].setdefault("event_breakdown", []).append(row)\r
                    break\r
            if found:\r
                break\r
        if not found:\r
            teams[team_id].setdefault("event_breakdown", []).append(row)\r
    else:\r
        teams[team_id].setdefault("event_breakdown", []).append(row)\r
\r
    for t in teams.values():\r
        _recompute_standings_team_totals(t)\r
\r
    _save("standings.json", standings)\r
    audit("standings_update", f"{team_id} {'-' if penalty else '+'}{points} ({event_name})")\r
    return jsonify({"ok": True, "team": standings["teams"].get(team_id)})\r
\r
\r
@admin_bp.route("/api/standings/delete-entry", methods=["POST"])\r
@login_required\r
def delete_standings_entry():\r
    body = request.get_json(silent=True) or {}\r
    entry_id = (body.get("entry_id") or "").strip()\r
    if not entry_id:\r
        return jsonify({"ok": False, "error": "entry_id required"}), 400\r
\r
    standings = _load("standings.json", {"teams": {}})\r
    teams = standings.get("teams", {})\r
    _ensure_standings_entry_ids(standings)\r
    removed = False\r
    for t in teams.values():\r
        rows = t.setdefault("event_breakdown", [])\r
        new_rows = [r for r in rows if r.get("id") != entry_id]\r
        if len(new_rows) != len(rows):\r
            t["event_breakdown"] = new_rows\r
            removed = True\r
    if not removed:\r
        return jsonify({"ok": False, "error": "Entry not found"}), 404\r
\r
    for t in teams.values():\r
        _recompute_standings_team_totals(t)\r
    _save("standings.json", standings)\r
    audit("standings_delete", entry_id)\r
    return jsonify({"ok": True})\r
\r
\r
@admin_bp.route("/api/standings/entries", methods=["GET"])\r
@login_required\r
def standings_entries():\r
    standings = _load("standings.json", {"teams": {}})\r
    _ensure_standings_entry_ids(standings)\r
    rows = []\r
    for team_id, team in (standings.get("teams") or {}).items():\r
        for row in (team.get("event_breakdown") or []):\r
            rows.append({\r
                "id": row.get("id"),\r
                "team_id": team_id,\r
                "team_name": team.get("name", team_id),\r
                "event": row.get("event", ""),\r
                "points": int(row.get("points", 0) or 0),\r
                "type": row.get("type", "points"),\r
                "note": row.get("note", ""),\r
            })\r
    return jsonify({"ok": True, "rows": rows})\r
\r
\r
def _ensure_standings_entry_ids(standings):\r
    changed = False\r
    for t in (standings.get("teams") or {}).values():\r
        rows = t.setdefault("event_breakdown", [])\r
        for row in rows:\r
            if not row.get("id"):\r
                row["id"] = "st-" + uuid.uuid4().hex[:10]\r
                changed = True\r
    if changed:\r
        _save("standings.json", standings)\r
\r
\r
def _recompute_standings_team_totals(team):\r
    rows = team.get("event_breakdown") or []\r
    points_earned = 0\r
    penalty_deductions = 0\r
    events_played = 0\r
    wins = 0\r
    for r in rows:\r
        pts = int(r.get("points", 0) or 0)\r
        kind = (r.get("type") or "").lower()\r
        is_penalty = (kind == "penalty") or pts < 0\r
        if is_penalty:\r
            penalty_deductions += abs(pts)\r
        else:\r
            points_earned += pts\r
            events_played += 1\r
            if pts >= 300:\r
                wins += 1\r
    team["points_earned"] = points_earned\r
    team["penalty_deductions"] = penalty_deductions\r
    team["events_played"] = events_played\r
    team["wins"] = wins\r
    team["net_points"] = points_earned - penalty_deductions\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Standings medals (gold / silver / bronze)\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/standings/medals", methods=["POST"])\r
@login_required\r
def update_medals():\r
    body = request.get_json(silent=True) or {}\r
    team_id = body.get("team")\r
    if team_id not in VALID_TEAM_IDS:\r
        return jsonify({"ok": False, "error": "Unknown team"}), 400\r
    try:\r
        gold = int(body.get("gold", 0) or 0)\r
        silver = int(body.get("silver", 0) or 0)\r
        bronze = int(body.get("bronze", 0) or 0)\r
    except (TypeError, ValueError):\r
        return jsonify({"ok": False, "error": "Medal counts must be numbers"}), 400\r
    if min(gold, silver, bronze) < 0:\r
        return jsonify({"ok": False, "error": "Medal counts cannot be negative"}), 400\r
\r
    standings = _load("standings.json", {"teams": {}})\r
    team = standings["teams"].get(team_id)\r
    if not team:\r
        return jsonify({"ok": False, "error": "Team not in standings"}), 400\r
\r
    team["gold"] = gold\r
    team["silver"] = silver\r
    team["bronze"] = bronze\r
    _save("standings.json", standings)\r
    audit("medals_update", f"{team_id} g{gold} s{silver} b{bronze}")\r
    return jsonify({"ok": True, "team": team})\r
\r
\r
# ---------------------------------------------------------------------------\r
# Write API â€” Award leaderboards (Overall MVP + Fair Play)\r
# ---------------------------------------------------------------------------\r
@admin_bp.route("/api/award-leaderboards/upsert", methods=["POST"])\r
@login_required\r
def upsert_award_leaderboard():\r
    body = request.get_json(silent=True) or {}\r
    board = (body.get("board") or "").strip().lower()\r
    if board not in {"overall_mvp", "fair_play"}:\r
        return jsonify({"ok": False, "error": "Unknown board"}), 400\r
\r
    leaderboards = _load("award_leaderboards.json", {"overall_mvp": [], "fair_play": []})\r
    rows = leaderboards.setdefault(board, [])\r
    row_id = (body.get("id") or "").strip()\r
\r
    if board == "overall_mvp":\r
        player_name = (body.get("player_name") or "").strip()\r
        team_name = (body.get("team_name") or "").strip()\r
        if not player_name or not team_name:\r
            return jsonify({"ok": False, "error": "Player and team are required"}), 400\r
        try:\r
            gold = int(body.get("gold", 0) or 0)\r
            silver = int(body.get("silver", 0) or 0)\r
            points = int(body.get("points", 0) or 0)\r
        except (TypeError, ValueError):\r
            return jsonify({"ok": False, "error": "Gold, silver and points must be numbers"}), 400\r
        if min(gold, silver, points) < 0:\r
            return jsonify({"ok": False, "error": "Values cannot be negative"}), 400\r
\r
        payload = {\r
            "id": row_id or ("mvp-" + uuid.uuid4().hex[:10]),\r
            "player_name": player_name,\r
            "team_name": team_name,\r
            "gold": gold,\r
            "silver": silver,\r
            "points": points,\r
            "updated_at": datetime.now().strftime("%Y-%m-%d %H:%M"),\r
        }\r
    else:\r
        team_name = (body.get("team_name") or "").strip()\r
        if not team_name:\r
            return jsonify({"ok": False, "error": "Team name is required"}), 400\r
        try:\r
            fair_play_points = int(body.get("fair_play_points", 0) or 0)\r
        except (TypeError, ValueError):\r
            return jsonify({"ok": False, "error": "Fair play points must be a number"}), 400\r
        if fair_play_points < 0:\r
            return jsonify({"ok": False, "error": "Points cannot be negative"}), 400\r
\r
        payload = {\r
            "id": row_id or ("fp-" + uuid.uuid4().hex[:10]),\r
            "team_name": team_name,\r
            "fair_play_points": fair_play_points,\r
            "updated_at": datetime.now().strftime("%Y-%m-%d %H:%M"),\r
        }\r
\r
    replaced = False\r
    for idx, row in enumerate(rows):\r
        if row.get("id") == payload["id"]:\r
            rows[idx] = payload\r
            replaced = True\r
            break\r
    if not replaced:\r
        rows.append(payload)\r
\r
    _save("award_leaderboards.json", leaderboards)\r
    audit("award_board_upsert", f"{board} {payload['id']}")\r
    return jsonify({"ok": True, "leaderboards": leaderboards, "row": payload})\r
\r
\r
@admin_bp.route("/api/award-leaderboards/delete", methods=["POST"])\r
@login_required\r
def delete_award_leaderboard():\r
    body = request.get_json(silent=True) or {}\r
    board = (body.get("board") or "").strip().lower()\r
    row_id = (body.get("id") or "").strip()\r
    if board not in {"overall_mvp", "fair_play"}:\r
        return jsonify({"ok": False, "error": "Unknown board"}), 400\r
    if not row_id:\r
        return jsonify({"ok": False, "error": "id required"}), 400\r
\r
    leaderboards = _load("award_leaderboards.json", {"overall_mvp": [], "fair_play": []})\r
    rows = leaderboards.setdefault(board, [])\r
    leaderboards[board] = [row for row in rows if row.get("id") != row_id]\r
    _save("award_leaderboards.json", leaderboards)\r
    audit("award_board_delete", f"{board} {row_id}")\r
    return jsonify({"ok": True, "leaderboards": leaderboards})\r
\r
